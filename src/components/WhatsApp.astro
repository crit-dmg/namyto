---
interface Props {
  phone?: string;
}

const { phone = '74951234567' } = Astro.props;
const waUrl = `https://wa.me/${phone}?text=Здравствуйте! Интересует обслуживание.`;
---

<div class="wa">
  <a href={waUrl} target="_blank" rel="noopener" class="wa-btn" aria-label="Написать в WhatsApp">
    <svg width="28" height="28" viewBox="0 0 32 32" fill="none"><path d="M16 3C9.373 3 4 8.373 4 15c0 2.11.55 4.09 1.52 5.81L4 28l7.34-1.92A12.94 12.94 0 0016 27c6.627 0 12-5.373 12-12S22.627 3 16 3z" fill="#25D366"/><path d="M22.05 19.38c-.34.96-1.67 1.76-2.76 1.99-.74.16-1.71.29-4.97-1.07-4.17-1.74-6.85-5.98-7.06-6.26-.2-.27-1.65-2.2-1.65-4.2 0-2 1.05-2.99 1.42-3.4.34-.37.9-.54 1.43-.54.17 0 .33.01.47.02.41.02.61.04.88.68.34.8 1.16 2.83 1.26 3.04.1.2.17.44.04.7-.13.27-.2.44-.4.67-.2.24-.42.53-.6.71-.2.2-.41.42-.18.82.24.4 1.05 1.73 2.25 2.8 1.55 1.38 2.85 1.81 3.26 2.01.4.2.64.17.88-.1.24-.27 1.02-1.19 1.3-1.6.27-.4.54-.34.9-.2.37.13 2.33 1.1 2.73 1.3.4.2.67.3.77.47.1.17.1.96-.24 1.92z" fill="#fff"/></svg>
  </a>
</div>

<style>
  .wa {
    position: fixed; bottom: 28px; right: 28px; z-index: 200;
  }
  .wa-btn {
    width: 52px; height: 52px; background: #25D366;
    border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    box-shadow: 0 4px 16px rgba(37,211,102,.3);
    transition: transform .2s;
  }
  .wa-btn:hover { transform: scale(1.06); }
</style>
