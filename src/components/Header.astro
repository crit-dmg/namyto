---
interface Props {
  section?: 'business' | 'home';
}

const { section = 'business' } = Astro.props;
---

<header class="hdr" id="hdr">
  <div class="container">
    <div class="hdr-in">
      <a href="/" class="logo"><svg class="logo-mark" viewBox="0 0 48 48" fill="none"><rect x="8" y="6" width="6" height="36" rx="1" fill="#fff"/><rect x="34" y="6" width="6" height="36" rx="1" fill="#fff"/><rect x="14" y="19" width="20" height="5" rx="1" fill="#2A8F7A"/></svg>намыто</a>
      <nav class="hdr-nav" id="nav">
        <a href="#services">Услуги</a>
        <a href="#objects">Объекты</a>
        <a href="#process">Подход</a>
        <a href="#form">Связаться</a>
      </nav>
      <div class="hdr-right">
        <a href="tel:+74951234567" class="hdr-tel">+7 495 123-45-67</a>
        <a href="#form" class="hdr-cta">Связаться</a>
        <button class="burger" id="burger" aria-label="Меню" aria-expanded="false" aria-controls="nav">
          <span></span><span></span>
        </button>
      </div>
    </div>
  </div>
</header>

<style>
  .hdr {
    position: fixed; top: 0; left: 0; right: 0; z-index: 100;
    padding: 20px 0;
    transition: all .5s ease;
  }
  .hdr.s {
    background: rgba(26,35,50,.96);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    padding: 14px 0;
  }
  .hdr-in {
    display: flex; align-items: center; gap: 20px;
  }
  .logo {
    font-family: var(--serif);
    font-size: 22px; font-weight: 700;
    color: var(--white); letter-spacing: -.01em;
    flex-shrink: 0;
    display: flex; align-items: center; gap: 10px;
  }
  .logo-mark { width: 28px; height: 28px; flex-shrink: 0; }
  .hdr-nav { display: flex; gap: 28px; margin-left: auto; }
  .hdr-nav a {
    font-size: 13px; font-weight: 500; letter-spacing: .03em;
    color: var(--text-m); transition: color .3s; white-space: nowrap;
  }
  .hdr-nav a:hover { color: var(--white); }
  .hdr-right { display: flex; align-items: center; gap: 20px; margin-left: auto; flex-shrink: 0; }
  .hdr-tel {
    font-size: 15px; font-weight: 600; color: var(--white);
    letter-spacing: .01em; transition: color .3s; white-space: nowrap;
  }
  .hdr-tel:hover { color: var(--teal); }
  .hdr-cta {
    padding: 10px 22px;
    border: 1px solid var(--border-l);
    font-size: 12px; font-weight: 600; letter-spacing: .08em;
    text-transform: uppercase; color: var(--text);
    transition: all .3s; white-space: nowrap; flex-shrink: 0;
  }
  .hdr-cta:hover { border-color: var(--teal); color: var(--white); }
  .burger {
    display: none; background: none; border: none; cursor: pointer;
    width: 28px; height: 20px; position: relative; flex-shrink: 0;
  }
  .burger span {
    display: block; width: 100%; height: 1.5px;
    background: var(--white); position: absolute; left: 0;
    transition: all .3s ease;
  }
  .burger span:first-child { top: 4px; }
  .burger span:last-child { bottom: 4px; }
  .burger.open span:first-child { top: 50%; transform: translateY(-50%) rotate(45deg); }
  .burger.open span:last-child { bottom: auto; top: 50%; transform: translateY(-50%) rotate(-45deg); }

  @media (max-width: 960px) {
    .hdr-nav { display: none; }
    .burger { display: block; z-index: 202; }
    .hdr-nav.open {
      display: flex; position: fixed; top: 0; left: 0; right: 0; bottom: 0;
      background: var(--navy); z-index: 201;
      flex-direction: column; align-items: center; justify-content: flex-start;
      gap: 32px; margin-left: 0; padding-top: 120px;
    }
    .hdr-nav.open a { font-size: 22px; font-weight: 500; color: var(--text); letter-spacing: .02em; white-space: normal; }
  }
  @media (max-width: 600px) {
    .hdr-cta { display: none; }
  }
</style>

<script>
  const hdr = document.getElementById('hdr');
  window.addEventListener('scroll', () => hdr?.classList.toggle('s', scrollY > 60), { passive: true });

  const burger = document.getElementById('burger');
  const nav = document.getElementById('nav');

  function closeMenu() {
    burger?.classList.remove('open');
    nav?.classList.remove('open');
    burger?.setAttribute('aria-expanded', 'false');
    document.body.style.overflow = '';
  }

  burger?.addEventListener('click', () => {
    const isOpen = nav?.classList.toggle('open');
    burger.classList.toggle('open');
    burger.setAttribute('aria-expanded', String(isOpen));
    document.body.style.overflow = isOpen ? 'hidden' : '';
  });

  nav?.addEventListener('click', (e) => {
    if ((e.target as HTMLElement).tagName === 'A') closeMenu();
  });
</script>