  background: var(--white);
  padding: clamp(80px, 10vw, 140px) 0;
}
.cta-grid {
  display: grid;
  grid-template-columns: 1fr 400px;
  gap: clamp(40px, 6vw, 80px);
  align-items: center;
}
.cta-left h2 {
  font-family: var(--serif);
  font-size: clamp(28px, 3.2vw, 44px);
  font-weight: 700; color: var(--navy);
  letter-spacing: -.015em; line-height: 1.1;
  margin-bottom: 16px;
}
.cta-left p {
  font-size: 16px; color: var(--text-dm);
  line-height: 1.75; margin-bottom: 28px;
  max-width: 460px;
}
.cta-tel {
  font-family: var(--serif);
  font-size: 28px; font-weight: 700;
  color: var(--navy);
  border-bottom: 2px solid var(--border-d);
  padding-bottom: 4px; display: inline-block;
  transition: border-color .3s;
}
.cta-tel:hover { border-color: var(--teal); }
.cta-form {
  background: var(--navy); padding: clamp(32px, 4vw, 48px);
  box-shadow: 0 16px 48px rgba(26,35,50,.2);
}
.cta-form h3 {
  font-family: var(--serif);
  font-size: 20px; font-weight: 700;
  color: var(--white); margin-bottom: 24px;
}
.fm-estimate {
  display: flex; justify-content: space-between; align-items: baseline;
  padding: 14px 0; margin-bottom: 16px;
  border-top: 1px solid var(--border-l);
  border-bottom: 1px solid var(--border-l);
}
.fm-estimate-label {
  font-size: 11px; font-weight: 600; color: var(--text-m);
  text-transform: uppercase; letter-spacing: .06em;
}
.fm-estimate-value {
  font-family: var(--serif); font-size: 28px; font-weight: 700;
  color: var(--teal); letter-spacing: -.02em;
}
.fm-note { font-size: 12px; color: var(--text-m); margin-top: 12px; line-height: 1.5; }

@media (max-width: 960px) {
  .cta-grid { grid-template-columns: 1fr; }
  .cta-form { max-width: 400px; }
}
</style>
