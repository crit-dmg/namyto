<section class="cta" id="form">
<div class="container">
  <div class="cta-grid f">
    <div class="cta-left">
      <h2>Бесплатный выезд и расчёт — за 24 часа</h2>
      <p>Оставьте заявку — перезвоним, уточним детали и приедем на осмотр. Вы ничего не должны до подписания договора.</p>
      <a href="tel:+74951234567" class="cta-tel">+7 495 123-45-67</a>
    </div>
    <div class="cta-form">
      <h3>Заявка на расчёт</h3>
      <div class="fm-field"><label class="fm-label" for="fn">Имя</label><input type="text" class="fm-input" id="fn" placeholder="Как к вам обращаться"></div>
      <div class="fm-field"><label class="fm-label" for="fp">Телефон</label><input type="tel" class="fm-input" id="fp" placeholder="+7"></div>
      <div class="fm-field">
        <label class="fm-label" for="ct">Тип помещения</label>
        <select class="fm-input fm-select" id="ct">
          <option value="office">Офис</option><option value="bc">Бизнес-центр</option><option value="wh">Склад / производство</option><option value="rest">Ресторан / кафе</option><option value="mall">Торговый центр</option>
        </select>
      </div>
      <div class="fm-field"><label class="fm-label" for="ca">Площадь, м²</label><input type="number" class="fm-input" id="ca" placeholder="200" value="200" min="10"></div>
      <div class="fm-estimate">
        <span class="fm-estimate-label">Ориентир</span>
        <span class="fm-estimate-value" id="crv">9 000 ₽</span>
      </div>
      <button class="fm-btn" id="fm-submit">Отправить заявку</button>
      <p class="fm-note">Перезвоним в течение часа. Точная цена — после бесплатного осмотра объекта.</p>
    </div>
  </div>
</div>
</section>

<script>
const elCt=document.getElementById('ct'),elCa=document.getElementById('ca'),
      elCrv=document.getElementById('crv'),elFn=document.getElementById('fn'),
      elFp=document.getElementById('fp');

const R={office:{r:45,g:80,a:120},bc:{r:40,g:75,a:110},wh:{r:35,g:55,a:80},rest:{r:55,g:90,a:130},mall:{r:38,g:65,a:95}};
function fmt(n){return n.toLocaleString('ru-RU')+' ₽'}
function up(){elCrv.textContent=fmt(Math.max(+(elCa.value)||100,10)*R[elCt.value].r);}
elCt.addEventListener('input',up);
elCa.addEventListener('input',up);
up();

document.getElementById('fm-submit').addEventListener('click',()=>{
  const m=encodeURIComponent(`Заявка с сайта namyto.ru\n\nИмя: ${elFn.value||'Не указано'}\nТелефон: ${elFp.value||'Не указан'}\nТип: ${elCt.selectedOptions[0].text}\nПлощадь: ${elCa.value||'200'} м²\nОриентир: ${elCrv.textContent}`);
  window.open('https://wa.me/74951234567?text='+m,'_blank');
});
</script>

<style>
