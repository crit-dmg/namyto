---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import CtaForm from '../../components/CtaForm.astro';
import Footer from '../../components/Footer.astro';
import WhatsApp from '../../components/WhatsApp.astro';

const title = 'Уборка ресторанов и кафе Москва — от 50 ₽/м²';
const description = 'Профессиональная уборка ресторанов, кафе, баров в Москве. Утренняя и вечерняя уборка, мойка кухни, дезинфекция.';
---

<BaseLayout title={title} description={description}>
  <Header />

  <main>
    <section class="s-hero">
      <div class="container">
        <div class="breadcrumbs">
          <a href="/">Главная</a>
          <span>/</span>
          <span>Рестораны</span>
        </div>

        <h1>Уборка ресторанов и HoReCa</h1>

        <p>Специализированный клининг для ресторанов, кафе, баров. Утренняя подготовка к открытию, вечерняя уборка после закрытия. Все сотрудники с санкнижками.</p>

        <div class="hero-stats">
          <div class="stat-item">
            <div class="stat-label">Стоимость</div>
            <div class="stat-value">от 50 ₽/м²</div>
          </div>
          <div class="stat-item">
            <div class="stat-label">График</div>
            <div class="stat-value">утро/вечер</div>
          </div>
          <div class="stat-item">
            <div class="stat-label">Санкнижки</div>
            <div class="stat-value">100%</div>
          </div>
        </div>
      </div>
    </section>

    <section class="s-section bg-alt">
      <div class="container">
        <h2>Что входит в уборку ресторана</h2>
        <div class="grid-3">
          <div class="info-card">
            <div class="ic-num">01</div>
            <h3>Зал</h3>
            <p>Уборка зала для гостей: протирка столов, стульев, барной стойки. Мытьё полов, вывоз мусора.</p>
          </div>
          <div class="info-card">
            <div class="ic-num">02</div>
            <h3>Кухня</h3>
            <p>Мойка кухонного оборудования, вытяжек, полов. Дезинфекция поверхностей, удаление жира.</p>
          </div>
          <div class="info-card">
            <div class="ic-num">03</div>
            <h3>Санузлы</h3>
            <p>Тщательная дезинфекция сантехники, зеркал, плитки. Пополнение расходных материалов.</p>
          </div>
        </div>
      </div>
    </section>

    <CtaForm />
  </main>

  <Footer />
  <WhatsApp />
</BaseLayout>
