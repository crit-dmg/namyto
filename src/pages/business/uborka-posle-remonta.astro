---
import BusinessLayout from '../../layouts/BusinessLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import CtaForm from '../../components/CtaForm.astro';
import SchemaOrg from '../../components/SchemaOrg.astro';

const breadcrumbItems = [
  { name: 'Главная', href: '/' },
  { name: 'Услуги', href: '/business/' },
  { name: 'Уборка после ремонта', href: '/business/uborka-posle-remonta/' }
];

const faqData = [
  { q: 'Что входит в уборку после ремонта?', a: 'Удаление строительной пыли, очистка стен и полов, мойка окон и подоконников, уборка санузлов, вынос мусора. Всё — под ключ, с фотоотчётом.' },
  { q: 'Как быстро приедете после звонка?', a: 'Выезд в день обращения или на следующий день. Для срочных случаев — в течение 4 часов с доплатой 30%.' },
  { q: 'Нужно ли предоставлять оборудование?', a: 'Нет, привозим всё с собой: пылесосы, швабры, средства для разных поверхностей. Вам ничего не нужно закупать.' },
  { q: 'Работаете ли в выходные?', a: 'Да, работаем без выходных с 7:00 до 22:00. Для офисов удобнее проводить уборку в субботу или вечером в будни.' },
  { q: 'Какие сроки уборки?', a: 'Квартира 50 м² — 4-6 часов. Офис 100 м² — 6-8 часов. Помещение 500 м² — 1-2 дня. Точный срок назовём после осмотра.' },
  { q: 'Есть ли гарантия?', a: 'Да, 48 часов. Если найдёте недочёты — приедем и исправим бесплатно. Также предоставляем фотоотчёт до и после.' },
  { q: 'Вывозите ли строительный мусор?', a: 'Да, вынос и вывоз мусора входит в стоимость. Крупногабаритный мусор (гипсокартон, двери) — за доплату по договорённости.' },
  { q: 'Можно ли заказать уборку до сдачи объекта заказчику?', a: 'Да, это типичный сценарий для девелоперов и риелторов. Убираем перед показом, фотосессией или сдачей ключей. Работаем по ночам.' }
];
---

<BusinessLayout
  title="Уборка после ремонта в Москве | Построительная уборка офисов"
  description="Профессиональная уборка после ремонта в офисах и квартирах Москвы. Удаление строительной пыли, мойка окон, вывоз мусора. Цены от 120 ₽/м². Договор."
  keywords="уборка после ремонта, построительная уборка, уборка офиса после ремонта, удаление строительной пыли, мойка окон после ремонта"
>
  <Breadcrumbs items={breadcrumbItems} />

  <section class="sp-hero">
    <div class="container">
      <h1>Уборка после ремонта в Москве</h1>
      <p class="sp-hero-intro">Профессиональная построительная уборка офисов, квартир и коммерческих помещений. Удаление пыли, грязи и строительного мусора. Сдаём помещение «под ключ».</p>
      <div class="sp-hero-bar">
        <div class="sp-hero-bar-item">
          <div class="hb-label">Цена</div>
          <div class="hb-value">от 120 ₽/м²</div>
        </div>
        <div class="sp-hero-bar-item">
          <div class="hb-label">Время</div>
          <div class="hb-value">от 4 часов</div>
        </div>
        <div class="sp-hero-bar-item">
          <div class="hb-label">Выезд</div>
          <div class="hb-value">сегодня</div>
        </div>
        <div class="sp-hero-bar-item">
          <div class="hb-label">Гарантия</div>
          <div class="hb-value">48 часов</div>
        </div>
      </div>
    </div>
  </section>

  <section class="sp-section sp-section--off">
    <div class="container">
      <div class="sp-prose">
        <div class="sec-label">Состав</div>
        <h2>Что входит в уборку после ремонта</h2>
        <p>Комплексная очистка всех поверхностей от строительной пыли, грязи и остатков материалов.</p>
      </div>
      <div class="sp-zones">
        <div class="sp-zone">
          <h3>Помещения</h3>
          <ul>
            <li>Удаление строительной пыли со стен</li>
            <li>Мытьё полов и плинтусов</li>
            <li>Очистка дверей и дверных косяков</li>
            <li>Уборка розеток и выключателей</li>
            <li>Чистка радиаторов отопления</li>
          </ul>
        </div>
        <div class="sp-zone">
          <h3>Окна и подоконники</h3>
          <ul>
            <li>Мойка окон с обеих сторон</li>
            <li>Очистка подоконников</li>
            <li>Удаление краски и шпаклёвки</li>
            <li>Мытьё оконных рам</li>
            <li>Очистка откосов</li>
          </ul>
        </div>
        <div class="sp-zone">
          <h3>Санузлы и кухни</h3>
          <ul>
            <li>Мытьё кафельной плитки</li>
            <li>Очистка сантехники</li>
            <li>Удаление затирки и клея</li>
            <li>Мытьё кухонного гарнитура</li>
            <li>Дезинфекция поверхностей</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <section class="sp-section sp-section--dark">
    <div class="container">
      <div class="sp-prose">
        <div class="sec-label">Цены</div>
        <h2>Стоимость уборки после ремонта</h2>
        <p>Фиксированные цены без скрытых доплат. Итоговая стоимость зависит от площади, сложности и количества мусора.</p>
      </div>
      <div class="sp-table-wrap">
        <table class="sp-table">
          <thead>
            <tr><th>Тип помещения</th><th>Цена</th><th>Примерное время</th></tr>
          </thead>
          <tbody>
            <tr><td>Офис до 100 м²</td><td>от 120 ₽/м²</td><td>4-6 часов</td></tr>
            <tr><td>Офис 100-300 м²</td><td>от 100 ₽/м²</td><td>6-10 часов</td></tr>
            <tr><td>Офис 300-1000 м²</td><td>от 90 ₽/м²</td><td>1-2 дня</td></tr>
            <tr><td>Квартира после ремонта</td><td>от 150 ₽/м²</td><td>4-8 часов</td></tr>
            <tr><td>Торговое помещение</td><td>от 110 ₽/м²</td><td>по оценке</td></tr>
            <tr><td>Вывоз строительного мусора</td><td>от 5 000 ₽</td><td>—</td></tr>
          </tbody>
        </table>
      </div>
      <div class="sp-note">Точную цену назовём после осмотра или по фото. Выезд менеджера для оценки — бесплатно.</div>
    </div>
  </section>

  <section class="sp-section sp-section--off">
    <div class="container">
      <div class="sp-prose">
        <div class="sec-label">Объекты</div>
        <h2>Какие объекты обслуживаем</h2>
        <p>Работаем с любыми коммерческими и жилыми помещениями после строительства и ремонта.</p>
      </div>
      <div class="sp-zones" style="grid-template-columns: repeat(4, 1fr);">
        <div class="sp-zone">
          <h3>Офисы</h3>
          <p class="sp-zone-placeholder">Раздел в разработке</p>
        </div>
        <div class="sp-zone">
          <h3>Торговые помещения</h3>
          <p class="sp-zone-placeholder">Раздел в разработке</p>
        </div>
        <div class="sp-zone">
          <h3>Квартиры</h3>
          <p class="sp-zone-placeholder">Раздел в разработке</p>
        </div>
        <div class="sp-zone">
          <h3>Специальные объекты</h3>
          <p class="sp-zone-placeholder">Раздел в разработке</p>
        </div>
      </div>
    </div>
  </section>

  <section class="sp-section sp-section--light">
    <div class="container">
      <div class="sp-prose">
        <div class="sec-label">Процесс</div>
        <h2>Как проходит уборка после ремонта</h2>
        <p>От заявки до чистого помещения — чёткий регламент с фотоотчётом.</p>
      </div>
      <div class="sp-steps">
        <div class="sp-step">
          <div>
            <div class="sp-step-title">Заявка</div>
            <p>Звонок или WhatsApp. Укажите площадь, тип ремонта, адрес. Ответим в течение часа.</p>
          </div>
        </div>
        <div class="sp-step">
          <div>
            <div class="sp-step-title">Оценка</div>
            <p>Менеджер выезжает для оценки объёма работ и количества мусора.</p>
          </div>
        </div>
        <div class="sp-step">
          <div>
            <div class="sp-step-title">Договор</div>
            <p>Фиксируем перечень работ, стоимость, сроки. Предоплата 30%.</p>
          </div>
        </div>
        <div class="sp-step">
          <div>
            <div class="sp-step-title">Уборка</div>
            <p>Бригада работает по чек-листу. Профессиональная техника и средства.</p>
          </div>
        </div>
        <div class="sp-step">
          <div>
            <div class="sp-step-title">Приёмка</div>
            <p>Фотоотчёт до и после. Вы проверяете результат. Оплата по факту.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="sp-section sp-section--dark">
    <div class="container">
      <div class="sp-prose">
        <div class="sec-label">Вопросы</div>
        <h2>Часто задаваемые вопросы</h2>
      </div>
      <div class="sp-prose">
        <div class="sp-faq">
          {faqData.map((item, i) => (
            <details>
              <summary>{item.q}</summary>
              <div class="sp-faq-body">{item.a}</div>
            </details>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section class="sp-section sp-section--light">
    <div class="container">
      <div class="sp-prose">
        <div class="sec-label">Подробнее</div>
        <h2>Уборка после ремонта: важные детали</h2>

        <h3>Почему обычная уборка не подходит</h3>
        <p>После ремонта остаётся мелкая строительная пыль, которая проникает везде — в розетки, за плинтуса, в микротрещины. Обычная уборка не справляется: пыль размазывается, а не удаляется. Нужны специальные средства для растворения затирки, клея, краски — и профессиональное оборудование, которое мы привозим с собой.</p>

        <h3>Когда вызывать уборку</h3>
        <p>Оптимальное время — сразу после окончания строительных работ, до расстановки мебели. Так пыль удаляется полностью, без «мертвых зон» за шкафами и диванами. Если мебель уже стоит — переставим, уберём, вернём на место. Но это увеличивает время и стоимость.</p>

        <h3>Что делать со строительным мусором</h3>
        <p>Вынос мелкого мусора (обрезки кабеля, упаковка, пыль) входит в стоимость уборки. Крупногабаритный мусор — гипсокартон, старые двери, обрезки труб — вывозим за доплату. Стоимость зависит от объёма: от 3 000 ₽ за небольшую партию до 15 000 ₽ за полную машину.</p>

        <h3>Как проверяем качество</h3>
        <p>По чек-листу из 47 пунктов: отсутствие пыли на горизонтальных поверхностях, чистота стёкол без разводов, удаление следов от наклеек и защитной плёнки, дезинфекция санузлов. Делаем фото до и после каждой зоны. Вы получаете полный фотоотчёт.</p>

        <h3>Уборка для девелоперов и риелторов</h3>
        <p>Специальное направление — подготовка квартир к продаже или сдаче в аренду. Работаем ночью, чтобы не мешать показам. Оформляем акт выполненных работ для передачи управляющей компании. Повторная уборка перед заселением арендаторов — со скидкой 20%.</p>

        <h3>Как сократить расходы</h3>
        <p>Закажите уборку в будни — скидка 10%. Если ремонт ещё идёт — дождитесь полного окончания, чтобы не убирать дважды. Самостоятельно вывезите крупный мусор — сэкономите на вывозе. Комбинируйте уборку с мойкой окон и химчисткой — комплексная заявка дешевле поштучных услуг.</p>
      </div>
    </div>
  </section>

  <CtaForm />

  <SchemaOrg type="Service" data={{
    name: 'Уборка после ремонта в Москве',
    provider: { '@type': 'LocalBusiness', name: 'Намыто', url: 'https://namyto.ru' },
    areaServed: { '@type': 'City', name: 'Москва' },
    description: 'Профессиональная построительная уборка офисов, квартир и коммерческих помещений после ремонта. Удаление пыли, мойка окон, вывоз мусора.',
    offers: { '@type': 'Offer', priceCurrency: 'RUB', price: '120', priceSpecification: { '@type': 'UnitPriceSpecification', price: '120', priceCurrency: 'RUB', 'unitText': 'м²' } }
  }} />

  <SchemaOrg type="FAQPage" data={{
    mainEntity: faqData.map(item => ({
      '@type': 'Question',
      name: item.q,
      acceptedAnswer: { '@type': 'Answer', text: item.a }
    }))
  }} />

  <style>
    .sp-hero { padding: 120px 0 60px; background: var(--navy); }
    .sp-hero h1 { font-family: var(--serif); font-size: clamp(32px, 4vw, 56px); color: var(--white); margin-bottom: 20px; }
    .sp-hero-intro { font-size: 17px; color: var(--text); max-width: 720px; margin-bottom: 40px; line-height: 1.7; }
    .sp-hero-bar { display: grid; grid-template-columns: repeat(4, 1fr); gap: 24px; border-top: 1px solid var(--border-l); padding-top: 28px; }
    .sp-hero-bar-item .hb-label { font-size: 10px; font-weight: 600; letter-spacing: .14em; text-transform: uppercase; color: var(--text-m); margin-bottom: 6px; }
    .sp-hero-bar-item .hb-value { font-family: var(--serif); font-size: 16px; font-weight: 700; color: var(--white); }

    .sp-section { padding: clamp(60px, 8vw, 100px) 0; }
    .sp-section--light { background: var(--white); }
    .sp-section--dark { background: var(--navy); }
    .sp-section--off { background: var(--off); }

    .sp-prose { max-width: 760px; }
    .sp-section--light .sp-prose h2 { font-family: var(--serif); font-size: clamp(26px, 3vw, 40px); color: var(--navy); margin-bottom: 20px; }
    .sp-section--dark .sp-prose h2 { font-family: var(--serif); font-size: clamp(26px, 3vw, 40px); color: var(--white); margin-bottom: 20px; }
    .sp-section--off .sp-prose h2 { font-family: var(--serif); font-size: clamp(26px, 3vw, 40px); color: var(--navy); margin-bottom: 20px; }
    .sp-prose h3 { font-family: var(--serif); font-size: 20px; color: var(--navy); margin: 32px 0 12px 0; }
    .sp-section--dark .sp-prose h3 { color: var(--white); }
    .sp-prose h3:first-of-type { margin-top: 0; }
    .sp-section--light .sp-prose p { font-size: 15px; color: var(--text-dm); line-height: 1.7; margin: 0 0 20px 0; }
    .sp-section--dark .sp-prose p { font-size: 15px; color: var(--text); line-height: 1.7; margin: 0 0 20px 0; }
    .sp-section--off .sp-prose p { font-size: 15px; color: var(--text-dm); line-height: 1.7; margin: 0 0 20px 0; }
    .sp-prose p:last-child { margin-bottom: 0; }

    .sp-zones { display: grid; grid-template-columns: repeat(3, 1fr); gap: 24px; margin: 40px 0; }
    .sp-zone { background: var(--white); padding: 24px; }
    .sp-section--dark .sp-zone { background: var(--navy-2); }
    .sp-section--off .sp-zone { background: var(--white); }
    .sp-zone h3 { font-family: var(--serif); font-size: 18px; color: var(--navy); margin-bottom: 16px; }
    .sp-section--dark .sp-zone h3 { color: var(--white); }
    .sp-zone ul { list-style: none; padding: 0; margin: 0; }
    .sp-zone li { font-size: 14px; color: var(--text-dm); padding: 6px 0; padding-left: 16px; position: relative; }
    .sp-section--dark .sp-zone li { color: var(--text-m); }
    .sp-zone li::before { content: ''; position: absolute; left: 0; top: 14px; width: 5px; height: 5px; background: var(--teal); border-radius: 50%; }

    .sp-table-wrap { margin: 40px 0; overflow-x: auto; }
    .sp-table { width: 100%; border-collapse: collapse; table-layout: fixed; }
    .sp-section--light .sp-table th,
    .sp-section--dark .sp-table th { text-align: left; padding: 14px 16px; font-size: 11px; font-weight: 600; letter-spacing: .08em; text-transform: uppercase; color: var(--text-dm); border-bottom: 1px solid var(--border-d); background: var(--off); vertical-align: middle; }
    .sp-section--light .sp-table td,
    .sp-section--dark .sp-table td { text-align: left; padding: 14px 16px; font-size: 15px; color: var(--text-dm); border-bottom: 1px solid var(--border-d); background: var(--white); vertical-align: middle; }
    .sp-section--light .sp-table tr:hover td,
    .sp-section--dark .sp-table tr:hover td { background: var(--off); }
    .sp-table th:nth-child(1),
    .sp-table td:nth-child(1) { width: 40%; }
    .sp-table th:nth-child(2),
    .sp-table td:nth-child(2) { width: 25%; }
    .sp-table th:nth-child(3),
    .sp-table td:nth-child(3) { width: 35%; }

    .sp-note { background: var(--navy-2); padding: 20px 24px; border-left: 3px solid var(--teal); margin: 32px 0; font-size: 15px; color: var(--text); }

    .sp-steps { display: grid; grid-template-columns: repeat(5, 1fr); gap: 24px; margin: 40px 0; }
    .sp-step { padding: 24px; background: var(--navy-2); border-top: 2px solid var(--teal); }
    .sp-step-title { font-family: var(--serif); font-size: 18px; font-weight: 700; color: var(--white); margin-bottom: 10px; }
    .sp-step p { font-size: 13px; color: var(--text-m); line-height: 1.6; }

    .sp-faq { margin-top: 24px; }
    .sp-faq details { border-bottom: 1px solid var(--border-d); }
    .sp-section--dark .sp-faq details { border-bottom-color: var(--border-l); }
    .sp-faq summary { font-size: 16px; font-weight: 600; color: var(--navy); padding: 20px 0; cursor: pointer; list-style: none; display: flex; justify-content: space-between; align-items: center; }
    .sp-section--dark .sp-faq summary { color: var(--white); }
    .sp-faq summary::after { content: '+'; font-size: 20px; color: var(--teal); }
    .sp-faq details[open] summary::after { content: '—'; }
    .sp-faq-body { padding: 0 0 20px; font-size: 15px; color: var(--text-dm); line-height: 1.7; }
    .sp-section--dark .sp-faq-body { color: var(--text); }

    @media (max-width: 960px) {
      .sp-hero-bar { grid-template-columns: repeat(2, 1fr); }
      .sp-zones { grid-template-columns: 1fr 1fr; }
      .sp-steps { grid-template-columns: repeat(3, 1fr); }
    }
    @media (max-width: 600px) {
      .sp-hero-bar { grid-template-columns: 1fr; }
      .sp-zones { grid-template-columns: 1fr; }
      .sp-steps { grid-template-columns: 1fr; }
    }
  </style>
</BusinessLayout>
