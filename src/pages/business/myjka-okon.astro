---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import CtaForm from '../../components/CtaForm.astro';
import Footer from '../../components/Footer.astro';
import WhatsApp from '../../components/WhatsApp.astro';

const title = 'Мойка окон в офисе Москва от 250 ₽/окно';
const description = 'Профессиональная мойка окон в офисах Москвы. Работаем на любой высоте, с гарантией качества.';
---

<BaseLayout title={title} description={description}>
  <Header />

  <main>
    <section class="s-hero">
      <div class="container">
        <div class="breadcrumbs">
          <a href="/">Главная</a>
          <span>/</span>
          <span>Мойка окон</span>
        </div>

        <h1>Мойка окон в офисе</h1>

        <p>Моем окна любой высоты и сложности. Работаем с промышленными альпинистами для высотных объектов. Чистота без разводов.</p>

        <div class="hero-stats">
          <div class="stat-item">
            <div class="stat-label">Обычное окно</div>
            <div class="stat-value">от 250 ₽</div>
          </div>
          <div class="stat-item">
            <div class="stat-label">Панорамное</div>
            <div class="stat-value">от 500 ₽</div>
          </div>
          <div class="stat-item">
            <div class="stat-label">Высота</div>
            <div class="stat-value">любая</div>
          </div>
        </div>
      </div>
    </section>

    <section class="s-section bg-alt">
      <div class="container">
        <h2>Что входит в мойку окон</h2>
        <div class="grid-3">
          <div class="info-card">
            <div class="ic-num">01</div>
            <h3>Стекла</h3>
            <p>Мойка стекол с обеих сторон. Удаление пыли, грязи, следов дождя. Без разводов и разводов.</p>
          </div>
          <div class="info-card">
            <div class="ic-num">02</div>
            <h3>Рамы и откосы</h3>
            <p>Очистка рам, подоконников, откосов. Удаление пыли и загрязнений из труднодоступных мест.</p>
          </div>
          <div class="info-card">
            <div class="ic-num">03</div>
            <h3>Москитные сетки</h3>
            <p>Чистка москитных сеток, жалюзи. Работаем аккуратно, не повреждаем конструкции.</p>
          </div>
        </div>
      </div>
    </section>

    <CtaForm />
  </main>

  <Footer />
  <WhatsApp />
</BaseLayout>
