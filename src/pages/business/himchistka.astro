---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import CtaForm from '../../components/CtaForm.astro';
import Footer from '../../components/Footer.astro';
import WhatsApp from '../../components/WhatsApp.astro';

const title = 'Химчистка ковролина в офисе Москва от 90 ₽/м²';
const description = 'Химчистка ковровых покрытий и мягкой мебели в офисах Москвы. Экстракторная чистка с выездом на объект.';
---

<BaseLayout title={title} description={description}>
  <Header />

  <main>
    <section class="s-hero">
      <div class="container">
        <div class="breadcrumbs">
          <a href="/">Главная</a>
          <span>/</span>
          <span>Химчистка</span>
        </div>

        <h1>Химчистка ковролина и мебели в офисе</h1>

        <p>Профессиональная чистка ковровых покрытий, кресел и диванов. Экстракторный метод — глубокое проникновение в волокна без повреждения ткани.</p>

        <div class="hero-stats">
          <div class="stat-item">
            <div class="stat-label">Ковролин</div>
            <div class="stat-value">от 90 ₽/м²</div>
          </div>
          <div class="stat-item">
            <div class="stat-label">Мебель</div>
            <div class="stat-value">от 500 ₽/место</div>
          </div>
          <div class="stat-item">
            <div class="stat-label">Выезд</div>
            <div class="stat-value">Москва</div>
          </div>
        </div>
      </div>
    </section>

    <section class="s-section bg-alt">
      <div class="container">
        <h2>Что входит в химчистку</h2>
        <div class="grid-3">
          <div class="info-card">
            <div class="ic-num">01</div>
            <h3>Ковровые покрытия</h3>
            <p>Экстракторная чистка ковролина в офисе. Удаление пыли, пятен, неприятных запахов. Сохнет 4-6 часов.</p>
          </div>
          <div class="info-card">
            <div class="ic-num">02</div>
            <h3>Мягкая мебель</h3>
            <p>Химчистка офисных кресел и диванов. Удаление загрязнений, дезинфекция, защитная пропитка по запросу.</p>
          </div>
          <div class="info-card">
            <div class="ic-num">03</div>
            <h3>Конференц-залы</h3>
            <p>Комплексная чистка ковров и мебели в переговорных и конференц-залах. Работаем в выходные.</p>
          </div>
        </div>
      </div>
    </section>

    <CtaForm />
  </main>

  <Footer />
  <WhatsApp />
</BaseLayout>
