---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import CtaForm from '../../components/CtaForm.astro';
import Footer from '../../components/Footer.astro';
import WhatsApp from '../../components/WhatsApp.astro';

const title = 'Уборка бизнес-центров Москва — от 45 ₽/м²';
const description = 'Комплексная уборка бизнес-центров в Москве. Ежедневный клининг, уборка МОП, вывоз мусора.';
---

<BaseLayout title={title} description={description}>
  <Header />

  <main>
    <section class="s-hero">
      <div class="container">
        <div class="breadcrumbs">
          <a href="/">Главная</a>
          <span>/</span>
          <span>Бизнес-центры</span>
        </div>

        <h1>Уборка бизнес-центров</h1>

        <p>Комплексное обслуживание БЦ и торговых центров. Уборка МОП, лестниц, лифтов, паркинга. Работаем круглосуточно.</p>

        <div class="hero-stats">
          <div class="stat-item">
            <div class="stat-label">Стоимость</div>
            <div class="stat-value">от 45 ₽/м²</div>
          </div>
          <div class="stat-item">
            <div class="stat-label">График</div>
            <div class="stat-value">24/7</div>
          </div>
          <div class="stat-item">
            <div class="stat-label">Бригада</div>
            <div class="stat-value">от 3 чел</div>
          </div>
        </div>
      </div>
    </section>

    <section class="s-section bg-alt">
      <div class="container">
        <h2>Что входит в уборку БЦ</h2>
        <div class="grid-3">
          <div class="info-card">
            <div class="ic-num">01</div>
            <h3>МОП</h3>
            <p>Уборка мест общего пользования: коридоры, лестницы, лифты, холлы. Ежедневная поддержание чистоты.</p>
          </div>
          <div class="info-card">
            <div class="ic-num">02</div>
            <h3>Санузлы</h3>
            <p>Чистка сантехники, дезинфекция, пополнение расходников. Работаем по ночам без мешать арендаторам.</p>
          </div>
          <div class="info-card">
            <div class="ic-num">03</div>
            <h3>Паркинг</h3>
            <p>Уборка подземного паркинга: мойка полов, вывоз мусора, чистка колёсных барьеров.</p>
          </div>
        </div>
      </div>
    </section>

    <CtaForm />
  </main>

  <Footer />
  <WhatsApp />
</BaseLayout>
