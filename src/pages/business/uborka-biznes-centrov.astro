---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import CtaForm from '../../components/CtaForm.astro';
import Footer from '../../components/Footer.astro';
import WhatsApp from '../../components/WhatsApp.astro';

const title = 'Уборка бизнес-центров Москва — профессиональный клининг от 45 ₽/м²';
const description = 'Комплексная уборка бизнес-центров, БЦ класса A, B, C. Поддержание премиального имиджа, работа 24/7, штатные уборщики.';
---

<BaseLayout title={title} description={description}>
  <Header />

  <main>
    <section class="bg-gradient-to-br from-slate-900 to-slate-800 text-white pt-32 pb-20">
      <div class="container mx-auto px-4">
        <div class="flex gap-2 text-sm text-slate-400 mb-6">
          <a href="/" class="text-teal-400 hover:underline">Главная</a>
          <span>/</span>
          <span>Бизнес-центры</span>
        </div>

        <h1 class="font-serif text-4xl md:text-5xl font-bold mb-5 max-w-2xl">
          Профессиональная уборка бизнес-центров
        </h1>

        <p class="text-lg text-slate-300 max-w-xl mb-10 leading-relaxed">
          Полный комплекс клининговых услуг для деловых центров любого класса. Поддерживаем репутацию вашего БЦ через безупречную чистоту.
        </p>

        <div class="flex flex-wrap gap-12">
          <div>
            <div class="text-xs uppercase tracking-widest text-slate-400 mb-1">Стоимость</div>
            <div class="text-2xl font-bold">от 45 ₽/м²</div>
          </div>
          <div>
            <div class="text-xs uppercase tracking-widest text-slate-400 mb-1">Площадь</div>
            <div class="text-2xl font-bold">от 1000 м²</div>
          </div>
          <div>
            <div class="text-xs uppercase tracking-widest text-slate-400 mb-1">Режим</div>
            <div class="text-2xl font-bold">24/7</div>
          </div>
        </div>
      </div>
    </section>

    <CtaForm />
  </main>

  <Footer />
  <WhatsApp />
</BaseLayout>
