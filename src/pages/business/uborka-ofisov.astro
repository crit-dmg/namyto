---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import CtaForm from '../../components/CtaForm.astro';
import Footer from '../../components/Footer.astro';
import WhatsApp from '../../components/WhatsApp.astro';

const title = 'Уборка офисов Москва — ежедневный клининг от 40 ₽/м²';
const description = 'Профессиональная уборка офисов в Москве. Ежедневный, генеральный, послеремонтный клининг. Работаем по договору, с НДС.';
---

<BaseLayout title={title} description={description}>
  <Header />

  <main>
    <section class="bg-gradient-to-br from-slate-900 to-slate-800 text-white pt-32 pb-20">
      <div class="container mx-auto px-4">
        <div class="flex gap-2 text-sm text-slate-400 mb-6">
          <a href="/" class="text-teal-400 hover:underline">Главная</a>
          <span>/</span>
          <span>Уборка офисов</span>
        </div>

        <h1 class="font-serif text-4xl md:text-5xl font-bold mb-5 max-w-2xl">
          Ежедневная уборка офисов в Москве
        </h1>

        <p class="text-lg text-slate-300 max-w-xl mb-10 leading-relaxed">
          Комплексная уборка рабочих помещений. Утренняя подготовка к работе, дневное поддержание чистоты, вечерняя уборка после смены.
        </p>

        <div class="flex flex-wrap gap-12">
          <div>
            <div class="text-xs uppercase tracking-widest text-slate-400 mb-1">Стоимость</div>
            <div class="text-2xl font-bold">от 40 ₽/м²</div>
          </div>
          <div>
            <div class="text-xs uppercase tracking-widest text-slate-400 mb-1">График</div>
            <div class="text-2xl font-bold">24/7</div>
          </div>
          <div>
            <div class="text-xs uppercase tracking-widest text-slate-400 mb-1">Договор</div>
            <div class="text-2xl font-bold">с НДС</div>
          </div>
        </div>
      </div>
    </section>

    <section class="py-20 bg-slate-950">
      <div class="container mx-auto px-4">
        <h2 class="font-serif text-3xl md:text-4xl font-bold text-white mb-12">
          Что входит в уборку офиса
        </h2>
        <div class="grid md:grid-cols-3 gap-8">
          <div class="bg-white p-8 border border-slate-200">
            <div class="text-3xl font-bold text-teal-500 mb-4 font-serif">01</div>
            <h3 class="text-lg font-semibold text-slate-900 mb-3">Рабочие зоны</h3>
            <p class="text-slate-600 text-sm leading-relaxed">
              Протирка поверхностей, уборка мусора, мытьё полов, очистка мебели от пыли. Чистые столы — чистые мысли.
            </p>
          </div>
          <div class="bg-white p-8 border border-slate-200">
            <div class="text-3xl font-bold text-teal-500 mb-4 font-serif">02</div>
            <h3 class="text-lg font-semibold text-slate-900 mb-3">Санузлы</h3>
            <p class="text-slate-600 text-sm leading-relaxed">
              Дезинфекция сантехники, чистка зеркал и кафеля, пополнение расходных материалов. Никаких разводов и запахов.
            </p>
          </div>
          <div class="bg-white p-8 border border-slate-200">
            <div class="text-3xl font-bold text-teal-500 mb-4 font-serif">03</div>
            <h3 class="text-lg font-semibold text-slate-900 mb-3">Общие зоны</h3>
            <p class="text-slate-600 text-sm leading-relaxed">
              Приёмная, переговорные, кухня, коридоры. Моём посуду, протираем технику, выносим мусор.
            </p>
          </div>
        </div>
      </div>
    </section>

    <CtaForm />
  </main>

  <Footer />
  <WhatsApp />
</BaseLayout>
