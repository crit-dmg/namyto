---
import BusinessLayout from '../../layouts/BusinessLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import CtaForm from '../../components/CtaForm.astro';
import SchemaOrg from '../../components/SchemaOrg.astro';

const breadcrumbs = [
  { name: 'Главная', href: '/' },
  { name: 'Услуги', href: '/#services' },
  { name: 'Генеральная уборка', href: '/business/generalnaya-uborka/' }
];

const faqData = [
  {
    q: 'Сколько стоит генеральная уборка офиса?',
    a: 'Стоимость от 80 ₽/м². Минимальный заказ — 15 000 ₽. Итоговая цена зависит от площади, степени загрязнения и количества дополнительных работ (мойка окон, химчистка). Точную сумму назовём после осмотра объекта.'
  },
  {
    q: 'Чем отличается генеральная от обычной уборки?',
    a: 'Ежедневная уборка поддерживает чистоту на видимых поверхностях. Генеральная — глубокая очистка всех зон: за шкафами, под мебелью, розетки, плинтуса, потолки, вентиляционные решётки. Удаляем накопившуюся за месяцы грязь и пыль.'
  },
  {
    q: 'Как быстро можно выехать на объект?',
    a: 'В день обращения — если объект в пределах МКАД. Для крупных помещений от 500 м² требуется планирование: подбор бригады, заказ спецтехники. Обычно — на следующий день после заявки.'
  },
  {
    q: 'Сколько времени занимает генеральная уборка?',
    a: 'Офис 100 м² — 4-5 часов. Офис 300 м² — 6-8 часов. Помещение 1000 м² — 1-2 дня. Срок зависит от степени загрязнения и дополнительных работ (мойка окон, химчистка ковров).'
  },
  {
    q: 'Генеральная уборка включает мойку окон?',
    a: 'Базовая стоимость включает протирку оконных рам и подоконников. Мойка стекол — отдельная услуга: от 250 ₽/окно внутри, от 400 ₽/окно снаружи (до 3 этажа). Для высотных работ привлекаем промышленных альпинистов.'
  },
  {
    q: 'Работаете ли в выходные?',
    a: 'Да. Генеральную уборку чаще заказывают на субботу или воскресенье, чтобы не мешать рабочему процессу. Бригада выезжает в удобное для вас время — с 7:00 утра.'
  },
  {
    q: 'Что нужно от заказчика?',
    a: 'Доступ в помещение, горячая вода, электричество. Химию, оборудование и расходники привозим сами. Если есть ценное оборудование — предупредите заранее, мы будем особенно аккуратны в этой зоне.'
  },
  {
    q: 'Даете ли гарантию?',
    a: 'Да. Если что-то не устроило — приедем и переделаем бесплатно в течение 48 часов. Также застрахованы на случай повреждения имущества — но такого ещё не случалось за 8 лет работы.'
  }
];
---

<BusinessLayout
  title="Генеральная уборка офиса в Москве от 80 ₽/м² — Намыто"
  description="Генеральная уборка офисов, складов, торговых помещений в Москве. Глубокая очистка всех поверхностей: полы, стены, потолки, труднодоступные зоны. Договор, фотоотчёт."
  ogTitle="Генеральная уборка офиса в Москве от 80 ₽/м² — Намыто"
  ogDescription="Генеральная уборка офисов, складов, торговых помещений в Москве. Глубокая очистка всех поверхностей. Договор, фотоотчёт."
>
  <Breadcrumbs items={breadcrumbs} />

  <section class="sp-hero">
    <div class="container">
      <h1>Генеральная уборка коммерческих помещений</h1>
      <p class="sp-hero-intro">Разовая глубокая уборка для приведения офиса, склада или торгового помещения в идеальное состояние. Моём всё: полы, стены, потолки, вентиляцию, труднодоступные зоны за мебелью и шкафами.</p>
      <div class="sp-hero-bar">
        <div class="sp-hero-bar-item"><div class="hb-label">Цена</div><div class="hb-value">От 80 ₽/м²</div></div>
        <div class="sp-hero-bar-item"><div class="hb-label">Минимум</div><div class="hb-value">15 000 ₽ за выезд</div></div>
        <div class="sp-hero-bar-item"><div class="hb-label">Срок</div><div class="hb-value">От 4 часов до 2 дней</div></div>
        <div class="sp-hero-bar-item"><div class="hb-label">Выезд</div><div class="hb-value">В день обращения по Москве</div></div>
      </div>
    </div>
  </section>

  <section class="sp-section sp-section--light">
    <div class="container">
      <div class="sp-prose">
        <div class="sec-label">Когда нужна</div>
        <h2>Три сценария генеральной уборки</h2>
        <p>Генеральная уборка не заменяет ежедневную, но решает задачи, которые накапливаются за месяцы работы.</p>
      </div>
      <div class="sp-zones">
        <div class="sp-zone">
          <h3>После ремонта</h3>
          <ul>
            <li>Удаление строительной пыли со всех поверхностей</li>
            <li>Очистка оконных рам и подоконников от герметика</li>
            <li>Мытьё полов от следов шпаклёвки и краски</li>
            <li>Удаление защитных плёнок и наклеек</li>
            <li>Протирка осветительных приборов и вентиляции</li>
            <li>Сдача помещения под ключ</li>
          </ul>
        </div>
        <div class="sp-zone">
          <h3>Перед важным событием</h3>
          <ul>
            <li>Подготовка к аудиту или инспекции</li>
            <li>Приёмка помещения при переезде</li>
            <li>Подготовка к визиту инвесторов или партнёров</li>
            <li>Офис должен сиять — уборка до мелочей</li>
            <li>Особое внимание видимым зонам</li>
            <li>Возможна срочная уборка в ночь</li>
          </ul>
        </div>
        <div class="sp-zone">
          <h3>Квартальная уборка</h3>
          <ul>
            <li>Даже при ежедневной уборке накапливается грязь</li>
            <li>Труднодоступные места: за шкафами, под столами</li>
            <li>Вентиляционные решётки и кондиционеры</li>
            <li>Стены, двери, плинтуса</li>
            <li>Розетки, выключатели, дверные ручки</li>
            <li>Возвращение свежести офису</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <section class="sp-section sp-section--dark">
    <div class="container">
      <div class="sp-prose">
        <div class="sec-label">Состав работ</div>
        <h2>Что входит в генеральную уборку</h2>
        <p>Перечень работ фиксируется в договоре перед началом. Вот стандартный набор для офиса площадью до 500 м².</p>
      </div>
      <div class="sp-zones">
        <div class="sp-zone">
          <h3>Полы и плинтуса</h3>
          <ul>
            <li>Подметание и удаление грубого мусора</li>
            <li>Влажная уборка всех типов покрытий</li>
            <li>Мытьё плинтусов и углов</li>
            <li>Под мебелью (при возможности сдвинуть)</li>
            <li>Дезинфекция в санузлах и кухне</li>
            <li>Ковролин — пылесос + при необходимости химчистка</li>
          </ul>
        </div>
        <div class="sp-zone">
          <h3>Стены и двери</h3>
          <ul>
            <li>Протирка стен от пыли и разводов</li>
            <li>Мытьё дверей с двух сторон</li>
            <li>Дверные коробки и наличники</li>
            <li>Очистка выключателей и розеток</li>
            <li>Протирка декоративных элементов</li>
            <li>Удаление пылинок и паутины</li>
          </ul>
        </div>
        <div class="sp-zone">
          <h3>Потолки и освещение</h3>
          <ul>
            <li>Пылесосим потолки и карнизы</li>
            <li>Чистка светильников и люстр</li>
            <li>Протирка кондиционеров (наружные блоки)</li>
            <li>Вентиляционные решётки и решётки</li>
            <li>Проверка работы освещения</li>
            <li>Сообщаем о неисправностях</li>
          </ul>
        </div>
        <div class="sp-zone">
          <h3>Окна и остекление</h3>
          <ul>
            <li>Протирка рам и подоконников</li>
            <li>Удаление пыли с откосов</li>
            <li>Мытьё стекол внутри (входит в базу)</li>
            <li>Мытьё стекол снаружи — дополнительно</li>
            <li>Очистка москитных сеток</li>
            <li>Подоконники с обеих сторон</li>
          </ul>
        </div>
        <div class="sp-zone">
          <h3>Мебель и техника</h3>
          <ul>
            <li>Протирка шкафов, столов, полок снаружи</li>
            <li>Протирка внутри шкафов (при открытии)</li>
            <li>Удаление пыли с оргтехники</li>
            <li>Протирка экранов мониторов</li>
            <li>Кресла и диваны — пылесос + химчистка</li>
            <li>Под мебелью — при возможности сдвинуть</li>
          </ul>
        </div>
        <div class="sp-zone">
          <h3>Санузлы и кухня</h3>
          <ul>
            <li>Дезинфекция всех сантехнических приборов</li>
            <li>Мытьё кафельной плитки и швов</li>
            <li>Чистка зеркал до блеска</li>
            <li>Кухня: столешницы, раковина, фасады</li>
            <li>Бытовая техника снаружи</li>
            <li>Вынос мусора, замена пакетов</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <section class="sp-section sp-section--light">
    <div class="container">
      <div class="sp-prose">
        <div class="sec-label">Стоимость</div>
        <h2>Цены на генеральную уборку</h2>
        <p>Стоимость зависит от площади, степени загрязнения и дополнительных работ. Минимальный заказ — 15 000 ₽.</p>
      </div>
      <div class="sp-table-wrap">
        <table class="sp-table">
          <thead>
            <tr><th>Площадь</th><th>Базовая стоимость</th><th>Срок</th></tr>
          </thead>
          <tbody>
            <tr><td>до 100 м²</td><td>15 000 ₽ (минимум)</td><td>4–5 часов</td></tr>
            <tr><td>100–200 м²</td><td>80 ₽/м²</td><td>5–7 часов</td></tr>
            <tr><td>200–500 м²</td><td>70 ₽/м²</td><td>1 день</td></tr>
            <tr><td>500–1000 м²</td><td>60 ₽/м²</td><td>1–2 дня</td></tr>
            <tr><td>от 1000 м²</td><td>Договорная</td><td>от 2 дней</td></tr>
          </tbody>
        </table>
      </div>
      <div class="sp-prose">
        <h3>Дополнительные услуги</h3>
        <div class="sp-zones" style="margin-top: 24px;">
          <div class="sp-zone">
            <h3>Мойка окон</h3>
            <ul>
              <li>Внутри: от 250 ₽/окно</li>
              <li>Снаружи (до 3 этажа): от 400 ₽/окно</li>
              <li>Высотная мойка: цена по запросу</li>
            </ul>
          </div>
          <div class="sp-zone">
            <h3>Химчистка</h3>
            <ul>
              <li>Ковролин: от 90 ₽/м²</li>
              <li>Кресла и стулья: от 300 ₽/шт</li>
              <li>Диваны: от 800 ₽/шт</li>
            </ul>
          </div>
          <div class="sp-zone">
            <h3>Уборка после ремонта</h3>
            <ul>
              <li>От 120 ₽/м²</li>
              <li>Удаление строительной пыли</li>
              <li>Мытьё всех поверхностей</li>
            </ul>
          </div>
        </div>
        <div class="sp-note">Точную цену назовём после бесплатного осмотра объекта. Выезд менеджера — в течение 24 часов.</div>
      </div>
    </div>
  </section>

  <section class="sp-section sp-section--off">
    <div class="container">
      <div class="sp-prose">
        <div class="sec-label">Сравнение</div>
        <h2>Генеральная vs ежедневная уборка</h2>
        <p>Две разные услуги для разных задач. Иногда нужна только ежедневная, иногда — только генеральная, чаще — обе.</p>
      </div>
      <div class="sp-compare">
        <div class="sp-compare-col sp-compare-col--muted">
          <h3>Ежедневная уборка</h3>
          <ul>
            <li>Поддерживает чистоту на видимых поверхностях</li>
            <li>Мусорные корзины, протирка столов</li>
            <li>Мытьё полов в проходимых зонах</li>
            <li>Уборка санузлов и кухни</li>
            <li>Не затрагивает труднодоступные места</li>
            <li>От 45 ₽/м² при регулярном обслуживании</li>
            <li>Идеально для поддержания порядка</li>
          </ul>
        </div>
        <div class="sp-compare-col sp-compare-col--accent">
          <h3>Генеральная уборка</h3>
          <ul>
            <li>Глубокая очистка всех поверхностей</li>
            <li>За мебелью, под мебелью, плинтуса</li>
            <li>Потолки, стены, вентиляция</li>
            <li>Розетки, выключатели, дверные ручки</li>
            <li>Удаление накопившейся за месяцы грязи</li>
            <li>От 80 ₽/м², минимум 15 000 ₽</li>
            <li>Идеально для восстановления чистоты</li>
          </ul>
        </div>
      </div>
      <div class="sp-prose">
        <p>Оптимальный вариант для большинства офисов: ежедневная уборка + генеральная раз в квартал. Это дешевле, чем постоянная генеральная уборка, и эффективнее, чем только ежедневная.</p>
      </div>
    </div>
  </section>

  <section class="sp-section sp-section--dark">
    <div class="container">
      <div class="sp-prose">
        <div class="sec-label">Процесс</div>
        <h2>Как проходит генеральная уборка</h2>
        <p>От заявки до сдачи объекта — чёткий регламент с фотоотчётом.</p>
      </div>
      <div class="sp-steps">
        <div class="sp-step">
          <div>
            <div class="sp-step-title">Заявка</div>
            <p>Звонок или WhatsApp. Укажите площадь помещения и желаемую дату. Ответим в течение часа.</p>
          </div>
        </div>
        <div class="sp-step">
          <div>
            <div class="sp-step-title">Осмотр</div>
            <p>Менеджер выезжает на объект для оценки работ. Бесплатно. Расчёт цены — в тот же день.</p>
          </div>
        </div>
        <div class="sp-step">
          <div>
            <div class="sp-step-title">Договор</div>
            <p>Фиксируем перечень работ, стоимость, сроки. Предоплата 50% или по факту — на ваш выбор.</p>
          </div>
        </div>
        <div class="sp-step">
          <div>
            <div class="sp-step-title">Уборка</div>
            <p>Бригада из 2-6 человек работает по чек-листу. Своя химия и оборудование. Контроль качества.</p>
          </div>
        </div>
        <div class="sp-step">
          <div>
            <div class="sp-step-title">Приёмка</div>
            <p>Фотоотчёт всех зон. Вы проверяете результат. Если нужно — доделываем на месте. Оплата.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="sp-section sp-section--light">
    <div class="container">
      <div class="sp-prose">
        <div class="sec-label">Вопросы</div>
        <h2>Часто задаваемые вопросы</h2>
      </div>
      <div class="sp-prose">
        <div class="sp-faq">
          {faqData.map((item, i) => (
            <details>
              <summary>{item.q}</summary>
              <div class="sp-faq-body">{item.a}</div>
            </details>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section class="sp-section sp-section--dark">
    <div class="container">
      <div class="sp-prose">
        <div class="sec-label">Подробнее</div>
        <h2>Генеральная уборка: что важно знать</h2>

        <h3>После ремонта — особый подход</h3>
        <p>После строительства или ремонта требуется не просто генеральная уборка, а послестроительная. Это разные услуги. Строительная пыль проникает везде: вентиляция, щели, ткани. Обычной уборки недостаточно.</p>
        <p>Для послеремонтной уборки используем промышленные пылесосы, специальные средства для удаления затвердевшей шпаклёвки и краски, промышленные мойки полов. Это дороже — от 120 ₽/м², но результат гарантирован.</p>

        <h3>Что моем, а что нет</h3>
        <p>В базовую генеральную уборку входит протирка всех доступных поверхностей. Но есть нюансы: мы не разбираем серверные стойки, не чистим внутри работающую оргтехнику, не моём стёкла снаружи на высоте (это отдельная услуга).</p>
        <p>Если в офисе есть ценное оборудование — предупредите заранее. Мы будем аккуратны, используем меньше влаги в этой зоне, применим сухие методы очистки.</p>

        <h3>Сезонные особенности</h3>
        <p>Весной и осенью генеральная уборка особенно актуальна. После зимы — уборка от песка и реагентов, которые занесли с улицы. Осенью — подготовка к отопительному сезону: чистка радиаторов, батарей, пространства за ними.</p>
        <p>Летом генеральную уборку чаще заказывают перед отпусками — чтобы вернуться в чистый офис. Зимой — перед новогодними праздниками и корпоративами.</p>

        <h3>Частота генеральной уборки</h3>
        <p>Для офисов с ежедневной уборкой: раз в квартал достаточно. Если ежедневной нет — раз в месяц. После ремонта — обязательно, даже если ремонт был косметическим.</p>
        <p>Медицинские кабинеты, лаборатории, пищевое производство — генеральная уборка чаще, по регламенту. Рассчитаем индивидуально.</p>

        <h3>Гарантия качества</h3>
        <p>После уборки вы получаете фотоотчёт ключевых зон. 48 часов на проверку: если что-то не устроило — приедем и переделаем бесплатно. За 8 лет работы таких случаев было меньше 1%, но правило работает.</p>
      </div>
    </div>
  </section>

  <CtaForm />

  <SchemaOrg type="Service" data={{
    name: 'Генеральная уборка офисов в Москве',
    provider: { '@type': 'LocalBusiness', name: 'Намыто', url: 'https://namyto.ru' },
    areaServed: { '@type': 'City', name: 'Москва' },
    description: 'Генеральная уборка офисов, складов, торговых помещений в Москве. Глубокая очистка всех поверхностей.',
    offers: { '@type': 'Offer', priceCurrency: 'RUB', price: '80', priceSpecification: { '@type': 'UnitPriceSpecification', price: '80', priceCurrency: 'RUB', unitText: 'м²' } }
  }} />

  <SchemaOrg type="FAQPage" data={{
    mainEntity: faqData.map(item => ({
      '@type': 'Question',
      name: item.q,
      acceptedAnswer: { '@type': 'Answer', text: item.a }
    }))
  }} />

  <style>
