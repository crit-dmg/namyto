---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import CtaForm from '../../components/CtaForm.astro';
import Footer from '../../components/Footer.astro';
import WhatsApp from '../../components/WhatsApp.astro';

const title = 'Генеральная уборка офиса Москва — от 80 ₽/м²';
const description = 'Разовая генеральная уборка офиса в Москве. Моём всё: полы, окна, санузлы, кухню. Бригада выезжает в день обращения.';
---

<BaseLayout title={title} description={description}>
  <Header />

  <main>
    <section class="s-hero">
      <div class="container">
        <div class="breadcrumbs">
          <a href="/">Главная</a>
          <span>/</span>
          <span>Генеральная уборка</span>
        </div>

        <h1>Генеральная уборка офиса</h1>

        <p>Разовая уборка для приведения офиса в идеальное состояние. До мелочей: моём полы, плинтуса, двери, розетки, выключатели.</p>

        <div class="hero-stats">
          <div class="stat-item">
            <div class="stat-label">Стоимость</div>
            <div class="stat-value">от 80 ₽/м²</div>
          </div>
          <div class="stat-item">
            <div class="stat-label">Минимум</div>
            <div class="stat-value">15 000 ₽</div>
          </div>
          <div class="stat-item">
            <div class="stat-label">Срок</div>
            <div class="stat-value">4–8 часов</div>
          </div>
        </div>
      </div>
    </section>

    <section class="s-section bg-alt">
      <div class="container">
        <h2>Когда нужна генеральная уборка</h2>
        <div class="grid-3">
          <div class="info-card">
            <div class="ic-num">01</div>
            <h3>После ремонта</h3>
            <p>Строительная пыль, следы от краски, герметика, шпаклёвки. Требуется промышленная мойка и удаление строительных загрязнений.</p>
          </div>
          <div class="info-card">
            <div class="ic-num">02</div>
            <h3>Перед важным событием</h3>
            <p>Аудит, приёмка помещения, переезд в новый офис, визит инвесторов. Офис должен сиять.</p>
          </div>
          <div class="info-card">
            <div class="ic-num">03</div>
            <h3>Раз в квартал</h3>
            <p>Даже при ежедневной уборке накапливаются загрязнения в труднодоступных местах. Генеральная уборка возвращает свежесть.</p>
          </div>
        </div>
      </div>
    </section>

    <CtaForm />
  </main>

  <Footer />
  <WhatsApp />
</BaseLayout>
