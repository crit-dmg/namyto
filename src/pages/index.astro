---
import BusinessLayout from '../layouts/BusinessLayout.astro';
import Hero from '../components/Hero.astro';
import About from '../components/About.astro';
import ServiceList from '../components/ServiceList.astro';
import ObjectGrid from '../components/ObjectGrid.astro';
import ProcessSteps from '../components/ProcessSteps.astro';
import FormatGrid from '../components/FormatGrid.astro';
import CtaForm from '../components/CtaForm.astro';
import SchemaOrg from '../components/SchemaOrg.astro';
---
<BusinessLayout
  title="Намыто — Обслуживание коммерческих помещений в Москве"
  description="Клининг для бизнеса. Договор, фотоотчёт, фиксированная цена. Офисы, склады, торговые центры. Москва и МО."
>
  <Hero />
  <About />
  <ServiceList />
  <ObjectGrid />
  <ProcessSteps />
  <FormatGrid />
  <CtaForm />
  <SchemaOrg type="LocalBusiness" data={{
    name: 'Намыто',
    description: 'Обслуживание коммерческих помещений в Москве',
    url: 'https://namyto.ru',
    telephone: '+74951234567',
    email: 'info@namyto.ru',
    address: { '@type': 'PostalAddress', addressLocality: 'Москва', addressCountry: 'RU' },
    areaServed: { '@type': 'City', name: 'Москва' },
    priceRange: '₽₽'
  }} />
</BusinessLayout>
